# INKR — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Stripe (optional — for Premium subscriptions) ───────────────────────────
# Found in: Stripe Dashboard > Developers > API keys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# ─── EAS / Expo ──────────────────────────────────────────────────────────────
# Found in: expo.dev > Project > Settings
# (Only needed for EAS Build / Submit — not for local dev)
# EXPO_TOKEN=your_expo_access_token_here
